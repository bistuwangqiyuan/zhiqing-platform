# ===== Database (Neon via Netlify extension) =====
# Auto-injected by Netlify when the Neon extension is installed on the site.
# For local dev, paste your connection string from Neon Console.
NETLIFY_DATABASE_URL=postgres://USER:PASSWORD@HOST/dbname?sslmode=require
NETLIFY_DATABASE_URL_UNPOOLED=postgres://USER:PASSWORD@HOST-pooler/dbname?sslmode=require
# Local-dev fallback (only used when NETLIFY_DATABASE_URL is unset)
DATABASE_URL=

# ===== Auth.js (NextAuth v5) =====
# `openssl rand -base64 32` — used to sign the session cookie.
AUTH_SECRET=replace-me-with-32-bytes-of-randomness
# Optional: from-address that magic links pretend to come from.
AUTH_EMAIL_FROM=noreply@zhiqing.local
# When unset, /api/auth/dev-link surfaces magic links so logins still work
# without an SMTP/Resend integration. Set to "1" to keep that behaviour
# explicit, or remove it once you wire a real email provider.
SHOW_DEV_MAGIC_LINK=1

# ===== Stripe =====
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# CLI `stripe listen --forward-to localhost:3000/api/stripe/webhook` prints this
STRIPE_WEBHOOK_SECRET=whsec_...
# Three one-time Prices created in Stripe Dashboard
STRIPE_PRICE_TOPUP_10=price_...
STRIPE_PRICE_TOPUP_50=price_...
STRIPE_PRICE_TOPUP_200=price_...

# ===== Anthropic =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== Site =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000
