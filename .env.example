# ===== Supabase =====
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...
# Service role key - server-only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# ===== Stripe =====
# Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# CLI `stripe listen --forward-to localhost:3000/api/stripe/webhook` prints this
STRIPE_WEBHOOK_SECRET=whsec_...
# Three one-time Prices created in Stripe Dashboard
STRIPE_PRICE_TOPUP_10=price_...
STRIPE_PRICE_TOPUP_50=price_...
STRIPE_PRICE_TOPUP_200=price_...

# ===== Anthropic =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== Site =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000
